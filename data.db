{"id":"63822bf1f968d427f73aa574","name":"文章X+2：秘鲁那些事（冲精）","contentLength":1115,"userID":"5e847a7005a093f5f4cb16bc","userName":"金戈气象","editorID":"5b4c496b13b8584a9e627f53","editorName":"耀天CH4","year":2022,"summary":"秘鲁寒流导致东南太平洋低温，形成独特渔场与生物群落。秘鲁私自扩展200海里领海引发争议，其邻国厄瓜多尔、智利及国际社会未予承认。文章还解析厄尔尼诺与拉尼娜现象对区域生态及渔业的影响，并概述秘鲁地理特征。","primaryDiscipline":"[\"地理学\",\"海洋科学\"]","secondaryDiscipline":"[\"自然地理学\",\"海洋生物学\",\"气候学\"]","keyWords":"[\"秘鲁寒流\",\"领海争议\",\"厄尔尼诺现象\",\"秘鲁渔场\",\"加拉帕戈斯群岛\",\"海洋温度异常\",\"热带气旋缺失\",\"生物多样性\"]","readability":0.65,"_id":"Y2AgfECsUtLNYztM","createdAt":{"$$date":1752228044363},"updatedAt":{"$$date":1752228044363}}
